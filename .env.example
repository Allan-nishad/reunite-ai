# REUNITE AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Atomesus AI API Key (optional) ─────────────────────────────────────
# Enables real Generative AI match assessment using the Atomesus "cipher" model.
# Without this key, the app uses a deterministic local inference engine as fallback.
# Get your key at: https://api.atomesus.com → Developer → API Keys
VITE_ATOMESUS_API_KEY=atms_sk_YOUR_KEY_HERE
